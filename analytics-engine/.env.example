# ─── Database Configuration ─────────────────────────────────
# Primary PostgreSQL (users, duels, questions)
PRIMARY_DATABASE_URL=postgresql://user:password@localhost:5432/clario_primary

# Telemetry PostgreSQL (attempt_history, interaction_logs)
TELEMETRY_DATABASE_URL=postgresql://user:password@localhost:5432/clario_telemetry

# TimescaleDB (learning progress time-series)
TIMESCALE_DATABASE_URL=postgresql://user:password@localhost:5433/clario_timescale

# ClickHouse (high-performance analytical queries)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DATABASE=clario_analytics

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Analytics Engine ──────────────────────────────────────
# Minimum attempts before marking a topic as weak/strong
MIN_ATTEMPTS_THRESHOLD=10

# Mastery thresholds
WEAK_TOPIC_ACCURACY_THRESHOLD=0.5
STRONG_TOPIC_ACCURACY_THRESHOLD=0.8

# ELO K-factor
ELO_K_FACTOR=32

# ─── API Server ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
