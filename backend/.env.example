PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/clario_primary
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Firebase Auth (choose ONE) ───────────────────────────────────────────────
# Option A: File path (local development)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Option B: JSON string (production on Render/Railway — paste full JSON contents)
# FIREBASE_CREDENTIALS={"type":"service_account","project_id":"...", ...}

FIREBASE_PROJECT_ID=your-firebase-project-id

# ─── Redis (optional, for duel event streaming) ───────────────────────────────
# REDIS_URL=rediss://default:PASSWORD@HOST:PORT

